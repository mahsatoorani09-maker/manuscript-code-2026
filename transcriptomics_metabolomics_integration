# Purpose: Integrate GSEA results (Transcriptomics) with MSEA results (Metabolomics)
# to find overlapping genes/features.

# -------------------------------------------------------------------------
# 1. Load Libraries
# -------------------------------------------------------------------------
if (!require("tidyverse")) install.packages("tidyverse")
library(tidyverse)

# -------------------------------------------------------------------------
# 2. Setup Paths (GitHub-ready)
# -------------------------------------------------------------------------
# We use relative paths instead of setwd("G:/...")
input_dir  <- "data/integration"
output_dir <- "results/integration"

# Create output directory if it doesn't exist
if (!dir.exists(output_dir)) dir.create(output_dir, recursive = TRUE)

# -------------------------------------------------------------------------
# 3. Read Transcriptomics Data (GSEA)


# Read all CSV files
df1 <- read_csv("REACTOME_DownRegulated.csv")
df2 <- read_csv("REACTOME_UpRegulated.csv")
df3 <- read_csv("KEGG_DownRegulated.csv")
df4 <- read_csv("KEGG_UpRegulated.csv")
df5 <- read_csv("GO_DownRegulated.csv")
df6 <- read_csv("GO_UpRegulated.csv")


##### TRANSCRIPTOMICS
library(tidyverse)

# A quick function to pad with NAs
pad_rows <- function(df, n) {
  if (nrow(df) < n) {
    df[(nrow(df)+1):n, ] <- NA
  }
  return(df)
}

# Find the max number of rows
max_rows <- max(nrow(df1), nrow(df2), nrow(df3), nrow(df4), nrow(df5), nrow(df6))

# Pad all to the same length
df1 <- pad_rows(df1, max_rows)
df2 <- pad_rows(df2, max_rows)
df3 <- pad_rows(df3, max_rows)
df4 <- pad_rows(df4, max_rows)
df5 <- pad_rows(df5, max_rows)
df6 <- pad_rows(df6, max_rows)

# Now bind_cols will work
combined_df <- bind_cols(df1, df2, df3, df4, df5, df6)

write.csv(combined_df, "combined_All_GSEA.csv", row.names = TRUE)


##### METABOLOMICS
meta_dat <- read.csv("MSEA_Quantitve.csv")
head(meta_dat)


###############################
# Check if Genes in Metabolomics data have overlap with transcriptomics data
genes1 <- combined_df %>% unlist(use.names = FALSE) %>% na.omit() %>% unique()
genes2 <- meta_dat %>% unlist(use.names = FALSE) %>% na.omit() %>% unique()


common_genes <- intersect(genes1, genes2)

# See how many and view them
length(common_genes)
head(common_genes)

write_csv(tibble(overlapping_genes = common_genes), "overlapping_genes.csv")
